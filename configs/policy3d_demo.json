{
  "experiment_id": "src-policy3d-demo",
  "seed": 42,
  "datasets": [
    {
      "manifest": {
        "dataset_id": "synthetic_demo",
        "name": "UEFS Synthetic 3D Policy Demo",
        "source_framework": "robo_train.synthetic",
        "source_uri": "memory://synthetic",
        "task_families": ["pick_place"],
        "robot_families": ["franka"],
        "splits": {
          "train": 0.8,
          "val": 0.2
        },
        "quality_flags": ["canonical_actions", "state_to_mock_point_cloud"],
        "lineage": {
          "generator": "SyntheticAdapter",
          "seed": 42
        }
      },
      "split": "train"
    }
  ],
  "training_profile": {
    "data_profile": "policy_3d",
    "model_family": "policy_3d",
    "loss_profile": "policy_3d_bc",
    "embodiment_profile": "franka_single_arm",
    "modalities": ["point_cloud", "state"],
    "action_space": "eef_delta_pose_gripper",
    "predicts_future": false
  },
  "policy": {
    "policy_type": "unified_mock",
    "latent_dim": 24,
    "action_horizon": 8
  },
  "trainer": {
    "algorithm": "behavior_cloning_3d",
    "max_epochs": 1,
    "batch_size": 2,
    "learning_rate": 0.0001
  },
  "tags": ["demo", "policy_3d", "behavior_cloning"]
}
