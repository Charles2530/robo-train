{
  "experiment_id": "src-synthetic-bc-demo",
  "seed": 42,
  "datasets": [
    {
      "manifest": {
        "dataset_id": "synthetic_demo",
        "name": "UEFS Synthetic Pick Place",
        "source_framework": "src.synthetic",
        "source_uri": "memory://synthetic",
        "task_families": ["pick_place"],
        "robot_families": ["franka"],
        "splits": {
          "train": 0.8,
          "val": 0.2
        },
        "sampling_weight": 1.0,
        "stats_path": "artifacts/synthetic_demo/stats.json",
        "quality_flags": ["validated_timestamps", "canonical_actions"],
        "lineage": {
          "generator": "SyntheticAdapter",
          "seed": 42
        }
      },
      "split": "train",
      "batch_weight": 1.0
    }
  ],
  "training_profile": {
    "data_profile": "vla",
    "model_family": "vla_policy",
    "loss_profile": "vla_bc",
    "embodiment_profile": "franka_single_arm",
    "modalities": ["front_rgb", "wrist_rgb", "language", "state"],
    "action_space": "eef_delta_pose_gripper",
    "predicts_future": false
  },
  "policy": {
    "policy_type": "unified_mock",
    "latent_dim": 32,
    "action_horizon": 8,
    "pretrained_checkpoint": null,
    "freeze_backbone": false
  },
  "trainer": {
    "algorithm": "behavior_cloning",
    "max_epochs": 1,
    "batch_size": 2,
    "learning_rate": 0.0001,
    "loss_weights": {
      "action": 1.0,
      "world_action": 0.1
    }
  },
  "tags": ["demo", "synthetic", "behavior_cloning"],
  "notes": "Minimal config-driven UEFS data and training infra demo inspired by LightX2V, LeRobot, and robomimic."
}
