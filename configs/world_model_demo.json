{
  "experiment_id": "src-world-model-demo",
  "seed": 42,
  "datasets": [
    {
      "manifest": {
        "dataset_id": "synthetic_demo",
        "name": "UEFS Synthetic World Model Demo",
        "source_framework": "robo_train.synthetic",
        "source_uri": "memory://synthetic",
        "task_families": ["pick_place"],
        "robot_families": ["aloha", "franka"],
        "splits": {
          "train": 0.8,
          "val": 0.2
        },
        "quality_flags": ["canonical_actions", "future_prediction_target"],
        "lineage": {
          "generator": "SyntheticAdapter",
          "seed": 42
        }
      },
      "split": "train"
    }
  ],
  "training_profile": {
    "data_profile": "world_model",
    "model_family": "world_action_model",
    "loss_profile": "world_model",
    "embodiment_profile": "aloha_dual_arm",
    "modalities": ["front_rgb", "state", "action", "future"],
    "action_space": "eef_delta_pose_gripper",
    "predicts_future": true
  },
  "policy": {
    "policy_type": "unified_mock",
    "latent_dim": 32,
    "action_horizon": 8
  },
  "trainer": {
    "algorithm": "world_action_modeling",
    "max_epochs": 1,
    "batch_size": 2,
    "learning_rate": 0.0001
  },
  "tags": ["demo", "world_model", "video_style_training"]
}
